---
const year = new Date().getFullYear();

const social = [
  { label: 'GitHub', href: 'https://github.com/rodrigomarchand', icon: 'gh' },
  { label: 'LinkedIn', href: 'https://www.linkedin.com/in/rodrigomarchand/', icon: 'li' },
  { label: 'Email', href: 'mailto:rodrigo.marchand@gmail.com', icon: 'em' },
];
---

<footer class="footer">
  <div class="container footer-inner">
    <div class="footer-left">
      <a href="/" class="footer-logo mono">rmarchand<span class="accent">.dev.br</span></a>
      <p class="footer-tagline">Construindo na interseção entre logística, agronegócio e tecnologia.</p>
    </div>

    <div class="footer-right">
      <div class="social-links">
        {social.map(s => (
          <a href={s.href} target="_blank" rel="noopener noreferrer" class="social-link" aria-label={s.label}>
            {s.label}
          </a>
        ))}
      </div>
    </div>
  </div>

  <div class="container footer-bottom">
    <span class="mono" style="font-size: 0.75rem; color: var(--text-muted);">
      &copy; {year} Rodrigo Marchand — Todos os direitos reservados
    </span>
    <span class="mono" style="font-size: 0.75rem; color: var(--text-muted);">
      Built with <span class="accent">Astro</span> + <span class="accent">&#9825;</span>
    </span>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--border);
    padding: 60px 0 32px;
    position: relative;
    z-index: 1;
  }

  .footer-inner {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 40px;
    margin-bottom: 48px;
  }

  .footer-logo {
    display: block;
    font-size: 1.1rem;
    font-weight: 500;
    color: var(--text-primary);
    margin-bottom: 10px;
    text-decoration: none;
    transition: color var(--transition);
  }
  .footer-logo:hover {
    color: var(--accent);
  }

  .footer-tagline {
    color: var(--text-secondary);
    font-size: 0.875rem;
    max-width: 300px;
    line-height: 1.6;
  }

  .social-links {
    display: flex;
    flex-direction: column;
    gap: 8px;
    align-items: flex-end;
  }

  .social-link {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--text-secondary);
    letter-spacing: 0.05em;
    transition: all var(--transition);
    padding: 4px 0;
    position: relative;
  }
  .social-link::after {
    content: '';
    position: absolute;
    bottom: 0;
    right: 0;
    width: 0;
    height: 1px;
    background: var(--accent);
    transition: width var(--transition);
  }
  .social-link:hover {
    color: var(--accent);
  }
  .social-link:hover::after {
    width: 100%;
  }

  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 24px;
    border-top: 1px solid var(--border);
  }

  @media (max-width: 600px) {
    .footer-inner {
      flex-direction: column;
    }
    .social-links {
      align-items: flex-start;
      flex-direction: row;
      flex-wrap: wrap;
      gap: 16px;
    }
    .footer-bottom {
      flex-direction: column;
      gap: 8px;
      text-align: center;
    }
  }
</style>
